				{
					"name": "Interswitch Webhook (Advanced)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Automatically compute the HMAC-SHA512 signature of the request body",
									"var secret = pm.collectionVariables.get('webhook_secret');",
									"if (!secret) {\n    console.warn('Set webhook_secret in collection variables to generate valid signature!');\n}",
									"var body = pm.request.body.raw;",
									"var hash = CryptoJS.HmacSHA512(body, secret);",
									"var signature = hash.toString(CryptoJS.enc.Hex);",
									"pm.request.headers.add({key: 'x-interswitch-signature', value: signature});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"paymentReference\": \"{{payment_ref}}\",\n    \"amount\": 500000,\n    \"transactionDate\": \"2023-10-01T12:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/webhooks/interswitch",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"webhooks",
								"interswitch"
							]
						}
					},
					"response": []
				},
